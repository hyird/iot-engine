config node 'node'
	option imei ''
	option model 'OpenWrt Edge'
	option heartbeat_interval_sec '30'

config platform 'primary'
	option enabled '0'
	option id '00000000-0000-0000-0000-000000000001'
	option url 'wss://example.invalid/edge/v1/connect'
	option enrollment_token_file '/etc/iot-edge/credentials/primary.token'
	option network_owner '1'
	option priority '100'
	option reconnect_interval_sec '5'
	option outbox_max_bytes '262144'
