config node 'node'
	option imei ''
	option model ''
	option heartbeat_interval_sec '30'

config hardware 'hardware'
	option serial_port '/dev/ttyS1'
	option lan_interface 'eth0'
	option wan_interface 'eth1'
	option bridge '0'
	option serial_rs485 '1'

config modem 'modem'
	option usb_vendor '3505'
	option usb_product '0003'
	option at_port '/dev/ttyUSB2'
	option status_path '/tmp/edgenode/modem.status'
	option monitor_interval '30'
	option imei ''
	option iccid ''
